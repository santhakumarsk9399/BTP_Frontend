{
  "name": "btp-app",
  "version": "1.0.0",
  "private": true,

  "main": "public/electron.cjs",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },

  "dependencies": {
    "axios": "^1.12.2",
    "formik": "^2.4.6",
    "lucide-react": "^0.552.0",
    "react": "^19.2.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.9.4",
    "react-toastify": "^11.0.5",
    "yup": "^1.7.1"
  },

  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "vite": "^7.1.7",

    "electron": "28.2.3",
    "electron-builder": "^24.9.1"
  },

  "build": {
    "asar": false,
    "appId": "com.delopt.btp",
    "productName": "BTP App",

    "directories": {
      "output": "release"
    },

    "files": [
      "dist/**/*",
      "public/electron.cjs"
    ],

    "win": {
      "target": "nsis"
    }
  }
}
